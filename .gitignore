# pyenv
#   For a library or app, you might want to share your .python-version.
#   See https://github.com/pyenv/pyenv/blob/master/COMMANDS.md#pyenv-version-file
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a newer python version, absolute path will fail.
#Pipfile.lock

# poetry
#   According to poetry documentation, the lock file should be tracked in version control.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Poetry and Pipenv, PDM recommends committing pdm.lock in version control.
#pdm.lock
#   pdm build pack target
.pdm-build/

# PEP 582; project local dependencies directory, written by pdm and python-launcher
__pypackages__/

