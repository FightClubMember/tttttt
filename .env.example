# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration
# Dev SQLite: sqlite+aiosqlite:///data.db
# Prod Postgres: postgresql+asyncpg://postgres:password@db:5432/marketplace
DATABASE_URL=sqlite+aiosqlite:///data.db

# Redis Caching (Leave empty to use in-memory fallback cache)
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# Administration (Comma-separated Telegram IDs)
ADMIN_IDS=123456789,987654321

# Bot Defaults (Can be modified via Admin settings DB)
BOT_NAME="Money Agent Marketplace"
CURRENCY_NAME="Credits"
SUPPORT_USERNAME=support_username

# Security
OTP_EXPIRY_SECONDS=120
RATE_LIMIT_COOLDOWN=0.5
